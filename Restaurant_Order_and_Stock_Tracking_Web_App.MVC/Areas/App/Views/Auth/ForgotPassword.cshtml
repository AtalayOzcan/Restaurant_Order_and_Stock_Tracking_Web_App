@* ──────────────────────────────────────────────────────────────────────────
   Areas/App/Views/Auth/ForgotPassword.cshtml
   SPRINT 6 — [FP] Şifremi Unuttum — Sadece Firma Kodu

   Sprint 5'ten fark: Email alanı kaldırıldı.
   Sistem Admin kullanıcısının emailini firmaKodu'ndan kendisi bulur.
────────────────────────────────────────────────────────────────────────── *@
@{
    Layout = null;
    ViewData["Title"] = "Şifre Sıfırlama";
}
<!DOCTYPE html>
<html lang="tr" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RestaurantOS — Şifre Sıfırlama</title>
    <script>(function(){var t=localStorage.getItem('ros-theme')||'dark';document.documentElement.setAttribute('data-theme',t);})();</script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700;1,800&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-bg" aria-hidden="true">
        <div class="auth-orb auth-orb-1"></div>
        <div class="auth-orb auth-orb-2"></div>
        <div class="auth-orb auth-orb-3"></div>
        <div class="auth-grid"></div>
    </div>

    <div class="auth-wrap">
        <a class="auth-back" asp-area="App" asp-controller="Auth" asp-action="Login">
            <span class="auth-back-arrow">←</span> Girişe Dön
        </a>

        <div class="auth-card">
            <div class="auth-logo">
                <span class="auth-logo-icon" aria-hidden="true">🍽</span>
                <span class="auth-logo-text">RestaurantOS</span>
                <span class="auth-logo-sub">Şifre Sıfırlama</span>
            </div>

            <h1 class="auth-title">Şifremi Unuttum</h1>
            <p class="auth-subtitle">
                Firma kodunuzu girin. Kayıtlı yönetici e-postasına doğrulama kodu göndereceğiz.
            </p>

            @* Önceki sıfırlamadan başarı mesajı *@
            @if (TempData["ResetSuccess"] is string succ)
            {
                <div class="auth-alert" style="border-left-color:#22C55E;margin-bottom:16px">
                    @succ
                </div>
            }

            @* Süresi dolmuş oturum uyarısı *@
            @if (TempData["ResetError"] is string resetErr)
            {
                <div class="auth-alert" role="alert" style="margin-bottom:16px">@resetErr</div>
            }

            @* Güvenli bilgi mesajı (var/yok aynı metin) *@
            @if (ViewBag.Info is string info)
            {
                <div class="auth-alert" style="border-left-color:#22C55E;margin-bottom:16px">
                    @info
                </div>
            }

            <form method="post"
                  asp-area="App"
                  asp-controller="Auth"
                  asp-action="ForgotPassword">
                @Html.AntiForgeryToken()

                <div class="auth-field">
                    <label class="auth-label" for="firmaKodu">Firma Kodu</label>
                    <input class="auth-input"
                           type="text"
                           id="firmaKodu"
                           name="firmaKodu"
                           placeholder="ornek-restoran-a1b2c3d4"
                           autocomplete="off"
                           autofocus />
                    <span class="auth-hint" style="font-size:12px;color:var(--text-muted,#6B7280);margin-top:4px;display:block">
                        Giriş ekranındaki "Firma Kodu" alanında yazan değeri girin.
                    </span>
                </div>

                <button type="submit"
                        class="auth-btn auth-btn--primary"
                        style="width:100%;margin-top:8px">
                    Doğrulama Kodu Gönder
                </button>
            </form>
        </div>
    </div>
</body>
</html>
