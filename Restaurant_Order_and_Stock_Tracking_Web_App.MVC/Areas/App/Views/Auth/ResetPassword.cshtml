@* ──────────────────────────────────────────────────────────────────────────
   Areas/App/Views/Auth/ResetPassword.cshtml
   SPRINT 6 — [FP] Yeni Şifre Belirleme

   Sprint 5'ten fark:
     - email hidden input kaldırıldı
     - resetToken hidden input eklendi (IMemoryCache doğrulama için)
     - firmaKodu hidden input korundu
────────────────────────────────────────────────────────────────────────── *@
@{
    Layout = null;
    ViewData["Title"] = "Yeni Şifre Belirleyin";
    var resetToken = ViewBag.ResetToken as string ?? "";
    var resetFirmaKodu = ViewBag.ResetFirmaKodu as string ?? "";
}
<!DOCTYPE html>
<html lang="tr" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RestaurantOS — Yeni Şifre</title>
    <script>(function(){var t=localStorage.getItem('ros-theme')||'dark';document.documentElement.setAttribute('data-theme',t);})();</script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700;1,800&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-bg" aria-hidden="true">
        <div class="auth-orb auth-orb-1"></div>
        <div class="auth-orb auth-orb-2"></div>
        <div class="auth-orb auth-orb-3"></div>
        <div class="auth-grid"></div>
    </div>

    <div class="auth-wrap">
        <div class="auth-card">
            <div class="auth-logo">
                <span class="auth-logo-icon" aria-hidden="true">🍽</span>
                <span class="auth-logo-text">RestaurantOS</span>
                <span class="auth-logo-sub">Yeni Şifre Belirleyin</span>
            </div>

            <h1 class="auth-title">Yeni Şifrenizi Girin</h1>
            <p class="auth-subtitle" style="text-align:center;font-size:13px;color:var(--text-muted,#6B7280)">
                Bu ekran 5 dakika geçerlilidir.
            </p>

            @if (ViewBag.Error is string err)
            {
                <div class="auth-alert" role="alert" style="margin-bottom:16px">@err</div>
            }

            <form method="post"
                  asp-area="App"
                  asp-controller="Auth"
                  asp-action="ResetPassword">
                @Html.AntiForgeryToken()

                @* [FP-7] IMemoryCache doğrulama için — email artık taşınmıyor *@
                <input type="hidden" name="resetToken" value="@resetToken" />
                <input type="hidden" name="firmaKodu" value="@resetFirmaKodu" />

                <div class="auth-field">
                    <label class="auth-label" for="newPassword">Yeni Şifre</label>
                    <div class="auth-input-wrap">
                        <input class="auth-input"
                               type="password"
                               id="newPassword"
                               name="newPassword"
                               placeholder="En az 8 karakter"
                               autocomplete="new-password"
                               autofocus />
                    </div>
                </div>

                <div class="auth-field">
                    <label class="auth-label" for="confirmPassword">Şifreyi Tekrarla</label>
                    <div class="auth-input-wrap">
                        <input class="auth-input"
                               type="password"
                               id="confirmPassword"
                               name="confirmPassword"
                               placeholder="Şifrenizi tekrar girin"
                               autocomplete="new-password" />
                    </div>
                </div>

                <button type="submit"
                        class="auth-btn auth-btn--primary"
                        style="width:100%;margin-top:8px">
                    Şifremi Güncelle
                </button>
            </form>
        </div>
    </div>
</body>
</html>
