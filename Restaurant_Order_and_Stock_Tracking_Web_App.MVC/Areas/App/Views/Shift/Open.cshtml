@{
    ViewData["Title"] = "Vardiya Aç";
}

@* [FE-01] SEC-02 Antiforgery token kaynağı *@
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery _af
@{
    var __afTokenValue = _af.GetAndStoreTokens(Context).RequestToken!;
}

@section Styles {
    <link href="~/css/Views/Shift/Index.css" rel="stylesheet" asp-append-version="true" />
    <style>
        /* ════════════════════════════════════════════════════
                   Shift/Open — Premium Input & CTA Layer
                   Mevcut .z-card, .btn-z sınıflarına ek katman.
                   ID'lere dokunulmaz; sadece class/style yönetimi.
                   ════════════════════════════════════════════════════ */

        .open-page-wrap {
            max-width: 520px;
            margin: 0 auto;
        }

        /* ── Hero ── */
        .open-hero {
            text-align: center;
            padding: 4px 0 28px;
        }

        .open-hero-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 72px;
            height: 72px;
            border-radius: 22px;
            background: linear-gradient(135deg, rgba(16,185,129,.18) 0%, rgba(16,185,129,.06) 100%);
            border: 1px solid rgba(16,185,129,.22);
            font-size: 34px;
            box-shadow: 0 4px 20px rgba(16,185,129,.15);
            margin-bottom: 14px;
        }

        .open-hero-title {
            font-family: 'Syne', sans-serif;
            font-size: 20px;
            font-weight: 800;
            color: var(--text);
            margin-bottom: 5px;
        }

        .open-hero-sub {
            font-size: 13px;
            color: var(--text-muted);
            line-height: 1.55;
        }

        /* ── Premium Field Grubu ── */
        .premium-field {
            margin-bottom: 20px;
        }

        .premium-label {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .07em;
            color: var(--text-muted);
            font-weight: 700;
            margin-bottom: 8px;
        }

        .lbl-required {
            color: #ef4444;
            font-size: 14px;
            line-height: 1;
        }

        /* Kapsayıcı — focus ring buraya */
        .premium-input-wrap {
            position: relative;
            border-radius: 14px;
            background: var(--surface);
            border: 1.5px solid var(--border);
            box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 12px rgba(0,0,0,.04);
            transition: border-color .2s ease, box-shadow .2s ease;
            overflow: hidden;
        }

            .premium-input-wrap:focus-within {
                border-color: #10b981;
                box-shadow: 0 0 0 4px rgba(16,185,129,.12), 0 4px 16px rgba(0,0,0,.08);
            }

        /* Para birimi prefix */
        .input-prefix {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            font-family: 'Syne', sans-serif;
            font-size: 18px;
            font-weight: 700;
            color: var(--text-muted);
            pointer-events: none;
            user-select: none;
            z-index: 1;
        }

        /* Büyük sayı input (Açılış Bakiyesi) */
        .premium-input-wrap input.premium-number {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            padding: 18px 20px 18px 54px;
            font-family: 'Syne', sans-serif;
            font-size: 28px;
            font-weight: 800;
            color: var(--text);
            letter-spacing: -.02em;
            line-height: 1;
            -moz-appearance: textfield;
        }

            .premium-input-wrap input.premium-number::-webkit-inner-spin-button,
            .premium-input-wrap input.premium-number::-webkit-outer-spin-button {
                -webkit-appearance: none;
            }

        /* Orta boy sayı input (Eşik) */
        .premium-input-wrap input.premium-number-sm {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            padding: 15px 20px 15px 52px;
            font-family: 'Syne', sans-serif;
            font-size: 22px;
            font-weight: 700;
            color: var(--text);
            letter-spacing: -.02em;
            -moz-appearance: textfield;
        }

            .premium-input-wrap input.premium-number-sm::-webkit-inner-spin-button,
            .premium-input-wrap input.premium-number-sm::-webkit-outer-spin-button {
                -webkit-appearance: none;
            }

        /* Textarea */
        .premium-input-wrap textarea.premium-textarea {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            padding: 16px 20px;
            font-size: 14px;
            font-weight: 500;
            color: var(--text);
            resize: vertical;
            min-height: 90px;
            font-family: inherit;
            line-height: 1.6;
        }

        .premium-hint {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 6px;
            padding-left: 2px;
            line-height: 1.5;
        }

        /* Ince bölücü çizgi */
        .open-divider {
            height: 1px;
            background: var(--border);
            margin: 24px 0;
            opacity: .5;
        }

        /* ── CTA Ana Butonu ── */
        .btn-open-cta {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 14px;
            padding: 20px 24px;
            border-radius: 16px;
            border: none;
            cursor: pointer;
            background: linear-gradient(135deg, #10b981 0%, #059669 60%, #047857 100%);
            color: #fff;
            font-family: 'Syne', sans-serif;
            font-size: 16px;
            font-weight: 800;
            letter-spacing: .01em;
            box-shadow: 0 4px 20px rgba(16,185,129,.36), 0 2px 6px rgba(0,0,0,.10);
            transition: transform .22s cubic-bezier(.34,1.56,.64,1), box-shadow .22s ease, opacity .2s;
            position: relative;
            overflow: hidden;
        }

            /* Shine sweep */
            .btn-open-cta::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,.22) 50%, transparent 60%);
                transform: translateX(-120%);
                transition: transform .55s ease;
            }

            .btn-open-cta:hover::before {
                transform: translateX(120%);
            }

            .btn-open-cta:hover {
                transform: translateY(-3px) scale(1.01);
                box-shadow: 0 10px 36px rgba(16,185,129,.44), 0 4px 12px rgba(0,0,0,.12);
            }

            .btn-open-cta:active {
                transform: translateY(0) scale(.99);
                box-shadow: 0 2px 10px rgba(16,185,129,.28);
            }

            .btn-open-cta:disabled {
                opacity: .55;
                cursor: not-allowed;
                transform: none !important;
                box-shadow: none !important;
            }

        .cta-icon {
            font-size: 22px;
            flex-shrink: 0;
        }

        .cta-text {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        .cta-text-main {
            font-size: 16px;
            font-weight: 800;
            line-height: 1.15;
        }

        .cta-text-sub {
            font-size: 11px;
            font-weight: 500;
            opacity: .72;
            letter-spacing: .03em;
            margin-top: 2px;
        }

        /* İptal linki */
        .btn-cancel-link {
            display: block;
            text-align: center;
            margin-top: 14px;
            font-size: 13px;
            color: var(--text-muted);
            text-decoration: none;
            transition: color .15s;
        }

            .btn-cancel-link:hover {
                color: var(--text);
            }

        /* Alert kutusu yuvarlak köşe override */
        #alertBox > div {
            border-radius: 12px !important;
        }

        /* Spin animasyonu (yükleniyor ikonu için) */
        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Responsive */
        @@media (max-width: 480px) {
            .premium-input-wrap input.premium-number {
                font-size: 24px;
                padding-left: 46px;
            }

            .input-prefix {
                font-size: 15px;
                left: 14px;
            }

            .btn-open-cta {
                padding: 17px 18px;
            }

            .cta-text-main {
                font-size: 15px;
            }
        }
    </style>
}

<div class="z-header">
    <div>
        <h1>🟢 Vardiya Aç</h1>
        <div class="sub">Gün başı kasa sayımını girerek vardiyayı başlatın.</div>
    </div>
    <a asp-action="Index" class="btn-z btn-z-ghost">← Geri</a>
</div>

<div id="alertBox"></div>

<div class="open-page-wrap">

    <div class="open-hero">
        <div class="open-hero-icon">🏦</div>
        <div class="open-hero-title">Gün Başı Kasa Sayımı</div>
        <div class="open-hero-sub">
            Kasadaki nakit miktarını ve uyarı eşiğini girerek<br>yeni vardiyayı başlatın.
        </div>
    </div>

    <div class="z-card" style="padding: 28px 28px 24px;">

        <div class="premium-field">
            <div class="premium-label">
                <span>💵</span>
                Açılış Bakiyesi
                <span class="lbl-required">*</span>
            </div>
            <div class="premium-input-wrap">
                <span class="input-prefix">₺</span>
                <input type="number"
                       id="openingBalance"
                       class="premium-number"
                       placeholder="0"
                       min="0"
                       step="0.01"
                       value="0"
                       inputmode="decimal" />
            </div>
            <div class="premium-hint">Gün başında kasadaki nakit miktarı.</div>
        </div>


        <div class="premium-field">
            <div class="premium-label">
                <span>⚠️</span>
                Fark Uyarı Eşiği
            </div>
            <div class="premium-input-wrap">
                <span class="input-prefix">₺</span>
                <input type="number"
                       id="threshold"
                       class="premium-number-sm"
                       placeholder="100"
                       min="0"
                       step="0.01"
                       value="100"
                       inputmode="decimal" />
            </div>
            <div class="premium-hint">Bu tutarı aşan kasa farklarında SignalR uyarısı gönderilir.</div>
        </div>

        <div class="open-divider"></div>

        <div class="premium-field" style="margin-bottom: 28px;">
            <div class="premium-label">
                <span>📝</span>
                Notlar
                <span style="font-size:10px;font-weight:500;text-transform:none;letter-spacing:0;opacity:.6;">(opsiyonel)</span>
            </div>
            <div class="premium-input-wrap">
                <textarea id="notes"
                          class="premium-textarea"
                          rows="3"
                          placeholder="Vardiyaya dair açıklama ekleyebilirsiniz…"></textarea>
            </div>
        </div>

        <button id="btnOpen" class="btn-open-cta">
            <span class="cta-icon">🚀</span>
            <span class="cta-text">
                <span class="cta-text-main">Vardiyayı Başlat</span>
                <span class="cta-text-sub">Kasa açılacak ve kayıt başlayacak</span>
            </span>
        </button>

        <a asp-action="Index" class="btn-cancel-link">İptal — Geri dön</a>

    </div>
</div>

@section Scripts {
    <script>
        // ── [FE-01] Antiforgery token — SEC-02 CSRF koruması için ────────────────
        const __afToken = '@__afTokenValue';

        const shiftId   = @Model.ShiftLogId;
        const fmt       = v => '₺' + Number(v).toLocaleString('tr-TR', {minimumFractionDigits:2, maximumFractionDigits:2});
        let sysCashVal  = 0;
        let sysOpenVal  = @Model.OpeningBalance.ToString(System.Globalization.CultureInfo.InvariantCulture);

        // ── Sistem verilerini AJAX ile çek ─────────────────────────────────────
        (async function loadPreview() {
            // [FE-01] fetch() → window.safeFetch()
            // PreviewTotals bir GET endpoint'i — CSRF token gerekmez,
            // ama safeFetch 401 koruması bu çağrıda da aktif.
            const res = await window.safeFetch(`/App/Shift/PreviewTotals/${shiftId}`);
            if (!res) return;   // 401 → modal gösterildi, sessizce dur

            if (!res.ok) { console.warn('PreviewTotals failed', res.status); return; }

            try {
                const d = await res.json();

                sysCashVal = d.totalCash ?? 0;
                sysOpenVal = d.openingBalance ?? sysOpenVal;

                document.getElementById('sysSales').textContent   = fmt(d.totalSales ?? 0);
                document.getElementById('sysCash').textContent    = fmt(d.totalCash ?? 0);
                document.getElementById('sysCard').textContent    = fmt(d.totalCard ?? 0);
                document.getElementById('sysOther').textContent   = fmt(d.totalOther ?? 0);
                document.getElementById('sysWaste').textContent   = fmt(d.totalWaste ?? 0);
                document.getElementById('sysOpening').textContent = fmt(d.openingBalance ?? sysOpenVal);

                if (d.differenceThreshold > 0)
                    document.getElementById('threshold').value = d.differenceThreshold;

                updateDiff();
            } catch (e) {
                console.error('PreviewTotals parse error:', e);
            }
        })();

        // ── Canlı fark önizleme ─────────────────────────────────────────────────
        document.getElementById('closingBalance').addEventListener('input', updateDiff);
        document.getElementById('threshold').addEventListener('input', updateDiff);

        function updateDiff() {
            const closing  = parseFloat(document.getElementById('closingBalance').value) || 0;
            const thr      = parseFloat(document.getElementById('threshold').value) || 100;
            const expected = sysOpenVal + sysCashVal;
            const diff     = closing - expected;
            const isOver   = Math.abs(diff) > thr;
            const hasInput = document.getElementById('closingBalance').value !== '';

            const elNum  = document.getElementById('diffPreview');
            const elBox  = document.getElementById('diffBox');
            const elNote = document.getElementById('diffNote');
            const elForm = document.getElementById('diffFormula');

            if (!hasInput) {
                elNum.textContent  = 'Kapanış bakiyesi girin…';
                elNum.style.color  = 'var(--text-muted)';
                elBox.className    = 'diff-preview-box';
                elNote.textContent = '';
                elForm.textContent = '';
                return;
            }

            elNum.textContent  = (diff >= 0 ? '+' : '') + fmt(diff);
            elNum.style.color  = isOver ? '#ef4444' : '#10b981';
            elBox.className    = 'diff-preview-box ' + (isOver ? 'warn' : 'ok');
            elForm.textContent = `${fmt(closing)} - (${fmt(sysOpenVal)} açılış + ${fmt(sysCashVal)} nakit) = ${(diff >= 0 ? '+' : '') + fmt(diff)}`;
            elForm.style.color = 'var(--text-muted)';
            elNote.textContent = isOver ? `⚠️ Uyarı eşiği ${fmt(thr)} aşılacak! SignalR uyarısı gönderilecek.` : '';
        }

        // ── Kapat ───────────────────────────────────────────────────────────────
        document.getElementById('btnClose').addEventListener('click', async function () {
            const closingBalance      = parseFloat(document.getElementById('closingBalance').value) || 0;
            const differenceThreshold = parseFloat(document.getElementById('threshold').value) || 100;
            const notes               = document.getElementById('notes').value.trim();
            const diff                = closingBalance - (sysOpenVal + sysCashVal);

            if (!confirm(
                `Vardiyayı kapatmak üzeresiniz.\n\n` +
                `Kapanış Kasası : ${fmt(closingBalance)}\n` +
                `Tahmini Fark   : ${(diff >= 0 ? '+' : '') + fmt(diff)}\n\n` +
                `Bu işlem geri alınamaz. Onaylıyor musunuz?`
            )) return;

            this.disabled    = true;
            this.textContent = 'Kapatılıyor…';

            // [FE-01] fetch() → window.safeFetch()
            // [SEC-02] RequestVerificationToken header'ı eklendi (CSRF koruması)
            const res = await window.safeFetch(`/App/Shift/Close/${shiftId}`, {
                method:  'POST',
                headers: { 'RequestVerificationToken': __afToken },
                body:    JSON.stringify({ closingBalance, notes, differenceThreshold })
            });

            if (!res) {                  // 401 → modal gösterildi
                this.disabled  = false;
                this.innerHTML = '⏹&nbsp; Vardiyayı Kapat &amp; Z Raporu Oluştur';
                return;
            }

            try {
                const d = await res.json();
                if (res.ok && d.success) {
                    window.location.href = `/App/Shift/Detail/${d.shiftId}`;
                } else {
                    showAlert(d.message || 'Vardiya kapatılamadı.');
                    this.disabled  = false;
                    this.innerHTML = '⏹&nbsp; Vardiyayı Kapat &amp; Z Raporu Oluştur';
                }
            } catch {
                showAlert('Sunucu yanıtı işlenemedi. Tekrar deneyin.');
                this.disabled  = false;
                this.innerHTML = '⏹&nbsp; Vardiyayı Kapat &amp; Z Raporu Oluştur';
            }
        });

        function showAlert(msg) {
            document.getElementById('alertBox').innerHTML =
                `<div style="background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.3);border-radius:10px;
                             padding:12px 16px;font-size:13px;color:#ef4444;margin-bottom:16px;display:flex;gap:8px;align-items:center">
                    <span>❌</span><span>${msg}</span>
                 </div>`;
        }
    </script>
}
