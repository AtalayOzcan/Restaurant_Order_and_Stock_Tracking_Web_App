@model IEnumerable<Restaurant_Order_and_Stock_Tracking_Web_App.MVC.Models.Category>
@{
    Layout = null;
    var tableName = (string)ViewData["TableName"]!;
    var isWaiterCalled = (bool)ViewData["IsWaiterCalled"]!;
    var lang = (ViewData["Lang"] as string ?? "tr").ToLower();
    var isRtl = lang == "ar";
    int itemCounter = 0;
    var romanNumerals = new[] { "I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX", "X", "XI", "XII" };
    int catIndex = 0;

    string CatName(Restaurant_Order_and_Stock_Tracking_Web_App.MVC.Models.Category cat) => lang switch
    {
        "en" => !string.IsNullOrWhiteSpace(cat.NameEn) ? cat.NameEn : cat.CategoryName,
        "ar" => !string.IsNullOrWhiteSpace(cat.NameAr) ? cat.NameAr : cat.CategoryName,
        "ru" => !string.IsNullOrWhiteSpace(cat.NameRu) ? cat.NameRu : cat.CategoryName,
        _ => cat.CategoryName
    };

    string ItemName(Restaurant_Order_and_Stock_Tracking_Web_App.MVC.Models.MenuItem item) => lang switch
    {
        "en" => !string.IsNullOrWhiteSpace(item.NameEn) ? item.NameEn : item.MenuItemName,
        "ar" => !string.IsNullOrWhiteSpace(item.NameAr) ? item.NameAr : item.MenuItemName,
        "ru" => !string.IsNullOrWhiteSpace(item.NameRu) ? item.NameRu : item.MenuItemName,
        _ => item.MenuItemName
    };

    string ItemDesc(Restaurant_Order_and_Stock_Tracking_Web_App.MVC.Models.MenuItem item) => lang switch
    {
        "en" => !string.IsNullOrWhiteSpace(item.DescriptionEn) ? item.DescriptionEn : (item.Description ?? ""),
        "ar" => !string.IsNullOrWhiteSpace(item.DescriptionAr) ? item.DescriptionAr : (item.Description ?? ""),
        "ru" => !string.IsNullOrWhiteSpace(item.DescriptionRu) ? item.DescriptionRu : (item.Description ?? ""),
        _ => item.Description ?? ""
    };

    var uiStrings = new Dictionary<string, Dictionary<string, string>>
    {
        ["digitalMenu"] = new() { ["tr"] = "Dijital Menü", ["en"] = "Digital Menu", ["ar"] = "القائمة الرقمية", ["ru"] = "Цифровое меню" },
        ["chefNote"] = new() { ["tr"] = "Şefin Notu", ["en"] = "Chef's Note", ["ar"] = "ملاحظة الشيف", ["ru"] = "Заметка шефа" },
        ["chefNoteText"] = new()
        {
            ["tr"] = "Tüm malzemelerimiz her sabah taze temin edilmektedir. Yemeklerimizi huzur içinde, sevdiklerinizle keyifle tüketmenizi dileriz.",
            ["en"] = "All our ingredients are freshly sourced every morning. We hope you enjoy our food with your loved ones.",
            ["ar"] = "جميع مكوناتنا طازجة يومياً. نتمنى لكم وجبة شهية مع أحبائكم.",
            ["ru"] = "Все наши ингредиенты поставляются свежими каждое утро. Приятного аппетита!"
        },
        ["chefName"] = new() { ["tr"] = "— Şef Mehmet Öz", ["en"] = "— Chef Mehmet Öz", ["ar"] = "— الشيف محمد أوز", ["ru"] = "— Шеф Мехмет Оз" },
        ["callWaiter"] = new() { ["tr"] = "Garson Çağır", ["en"] = "Call Waiter", ["ar"] = "نادِ النادل", ["ru"] = "Позвать официанта" },
        ["waiterCalled"] = new() { ["tr"] = "Garson Çağrıldı", ["en"] = "Waiter Called", ["ar"] = "تم استدعاء النادل", ["ru"] = "Официант вызван" },
        ["allItems"] = new() { ["tr"] = "Tümü", ["en"] = "All", ["ar"] = "الكل", ["ru"] = "Все" },
        ["limitedStock"] = new() { ["tr"] = "Sınırlı Stok", ["en"] = "Limited Stock", ["ar"] = "مخزون محدود", ["ru"] = "Ограниченный запас" },
        ["noProduct"] = new()
        {
            ["tr"] = "Şu anda aktif ürün bulunmamaktadır.",
            ["en"] = "No active products available at the moment.",
            ["ar"] = "لا توجد منتجات نشطة في الوقت الحالي.",
            ["ru"] = "В настоящее время активных продуктов нет."
        },
        ["thanks"] = new() { ["tr"] = "Bizi tercih ettiğiniz için teşekkür ederiz.", ["en"] = "Thank you for choosing us.", ["ar"] = "شكراً لاختياركم لنا.", ["ru"] = "Спасибо, что выбрали нас." },
        ["enjoy"] = new() { ["tr"] = "Afiyet Olsun", ["en"] = "Enjoy Your Meal", ["ar"] = "بالهناء والشفاء", ["ru"] = "Приятного аппетита" },
        ["connError"] = new() { ["tr"] = "Bağlantı hatası. Lütfen tekrar deneyiniz.", ["en"] = "Connection error. Please try again.", ["ar"] = "خطأ في الاتصال. حاول مجدداً.", ["ru"] = "Ошибка подключения. Попробуйте снова." },
        ["waiterMsg"] = new() { ["tr"] = "Garsonunuz en kısa sürede gelecek.", ["en"] = "Your waiter will be with you shortly.", ["ar"] = "سيأتي النادل إليك قريباً.", ["ru"] = "Официант скоро подойдёт к вам." },
    };
    string T(string key) => uiStrings.TryGetValue(key, out var d)
        ? (d.TryGetValue(lang, out var v) ? v : d["tr"])
        : key;
}
<!DOCTYPE html>
<html lang="@lang" @(isRtl? Html.Raw("dir=\"rtl\"") : Html.Raw(""))>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#FAF9F6" />
    <title>@tableName — @T("digitalMenu")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
    @if (lang == "ar")
    {
        <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@300;400;500;600&display=swap" rel="stylesheet" />
    }
    <link rel="stylesheet" href="~/css/Views/QrMenu/Index.css" asp-append-version="true" />
</head>
<body class="@(isRtl ? "rtl" : "")">
    <div class="qr-page">

     
        <header class="qr-header">
            <nav class="lang-switcher" aria-label="Dil seçimi">
                <button class="ls-item @(lang == "tr" ? "ls-active" : "")" onclick="setLang('tr')" aria-label="Türkçe">TR</button>
                <span class="ls-dot" aria-hidden="true">•</span>
                <button class="ls-item @(lang == "en" ? "ls-active" : "")" onclick="setLang('en')" aria-label="English">EN</button>
                <span class="ls-dot" aria-hidden="true">•</span>
                <button class="ls-item @(lang == "ar" ? "ls-active" : "")" onclick="setLang('ar')" aria-label="العربية">AR</button>
                <span class="ls-dot" aria-hidden="true">•</span>
                <button class="ls-item @(lang == "ru" ? "ls-active" : "")" onclick="setLang('ru')" aria-label="Русский">RU</button>
            </nav>

            <div class="header-eyebrow">✦ &nbsp; @T("digitalMenu") &nbsp; ✦</div>
            <h1 class="header-restaurant-name">Lezzet <em>Durağı</em></h1>
            <div class="header-table">@tableName</div>
        </header>

        <section class="chef-note-section" aria-label="@T("chefNote")">
            <div class="chef-note-inner">
                <div class="chef-note-label">@T("chefNote")</div>
                <p class="chef-note-quote">@T("chefNoteText")</p>
                <div class="chef-note-author">@T("chefName")</div>
            </div>
        </section>

        <div class="waiter-section">
            <button class="btn-waiter" id="btnCallWaiter" onclick="callWaiter()"
                    @(isWaiterCalled ? "disabled" : "") aria-label="@T("callWaiter")">
                    onclick="callWaiter()"
                    @(isWaiterCalled ? "disabled" : "")
                    aria-label="Garson çağır">
                    <span>@T("waiterCalled")</span>
                    @(isWaiterCalled ? "disabled" : "")
                    aria-label="Garson çağır">
                    onclick="callWaiter()"
                    @(isWaiterCalled ? "disabled" : "")
                    <span>@T("callWaiter")</span>
                    onclick="callWaiter()"
                    @(isWaiterCalled ? "disabled" : "")
                    aria-label="Garson çağır">
                    onclick="callWaiter()"
       KATEGORİ FİLTRE NAV — Sticky + Yatay Kaydırmalı
       "Tümü" her zaman ilk sırada; sonra DB'den gelen kategoriler.
       ════════════════════════════════════════════════════════ *@
                    aria-label="Garson çağır">
                    <button class="cat-nav-btn active" data-cat="all" onclick="filterCategory('all', this)">@T("allItems")</button>
                {
                    <span class="btn-waiter-icon">◌</span>
                        <button class="cat-nav-btn" data-cat="@cat.CategoryId" onclick="filterCategory('@cat.CategoryId', this)">@CatName(cat)</button>
        @* ════════════════════════════════════════════════════════
       KATEGORİ FİLTRE NAV — Sticky + Yatay Kaydırmalı
       "Tümü" her zaman ilk sırada; sonra DB'den gelen kategoriler.
       ════════════════════════════════════════════════════════ *@
        @if (Model.Any())
                    @* ── "Tümü" — sabit ilk buton ── *@
                    <button class="cat-nav-btn active"
            <div class="menu-empty">@T("noProduct")</div>
                    </button>

                    @* ── Veritabanından gelen kategoriler — dinamik ── *@
                    @foreach (var cat in Model)
                    {
                        <button class="cat-nav-btn"
                                data-cat="@cat.CategoryId"
                                onclick="filterCategory('@cat.CategoryId', this)">
                            @cat.CategoryName
                        </button>
                    }
                </div>
            </nav>
        }

        @* ════════════════════════════════════════════════════════
       MENÜ — Kategorilere göre Dinamik Bölümler
       Her section'a data-cat-id ekleniyor → JS filtrelemesi bu niteliğe bakar
       ════════════════════════════════════════════════════════ *@
        @if (!Model.Any())
        {
            <div class="menu-empty">
                Şu anda aktif ürün bulunmamaktadır.
            </div>
        }
        else
        {
            catIndex = 0;
            @foreach (var cat in Model)
            {
                var animDelay = 0.35 + (catIndex * 0.08);
                            bool isLowStock = item.TrackStock && item.StockQuantity > 0
                            && item.StockQuantity <= item.AlertThreshold && item.AlertThreshold > 0;
                            var displayName = ItemName(item);
                            var displayDesc = ItemDesc(item);
                            bool isLowStock = item.TrackStock && item.StockQuantity > 0
                            && item.StockQuantity <= item.AlertThreshold
                            && item.AlertThreshold > 0;
                            var detailUrl = $"/QrMenu/Detail/{item.MenuItemId}?tableName={Uri.EscapeDataString(tableName)}";
                         aria-labelledby="cat-title-@cat.CategoryId"
                            <div class="menu-item" role="listitem" tabindex="0"
                                 onclick="location.href='@detailUrl'"
                                 onkeydown="if(event.key==='Enter')location.href='@detailUrl'">

                                
                                <div class="item-thumb-col" aria-hidden="true">
                                    @if (!string.IsNullOrWhiteSpace(item.ImagePath))
                                    {
                                        <img class="item-thumb" src="@item.ImagePath" alt="@item.MenuItemName" loading="lazy" />
                                    }
                                    else
                                    {
                                        <div class="item-thumb-ph">🍽</div>
                                    }
                                </div>

                               
                        <div class="cat-divider-bottom">
                                    <div class="item-name">@displayName</div>
                                    @if (!string.IsNullOrWhiteSpace(displayDesc))
                                    <div class="item-name">
                                        @item.MenuItemName
                                        @if (!string.IsNullOrWhiteSpace(item.DetailedDescription) || !string.IsNullOrWhiteSpace(item.ImagePath))
                                        {
                                            <span class="item-arrow" aria-hidden="true">›</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(item.Description))
                        </div>
                    </div>

                    <div class="menu-list" role="list">
                        @foreach (var item in cat.MenuItems)
                                        <div class="item-tags"><span class="item-tag">@T("limitedStock")</span></div>

                            bool isLowStock = item.TrackStock
                                <div class="item-price-col" aria-label="Fiyat: @item.MenuItemPrice.ToString("N2") Türk Lirası">
                            <div class="menu-item" role="listitem">

                                @* Sütun 1: Numara *@
                                <div class="item-number" aria-hidden="true">@itemNo</div>

                                @* Sütun 2: İsim + Açıklama + Etiket *@
                                <div class="item-info">
                                    <div class="item-name">@item.MenuItemName</div>

                                    @if (!string.IsNullOrWhiteSpace(item.Description))
                                    {
                                        <div class="item-desc">@displayDesc</div>
                                    }
                                    @if (isLowStock)
                                    {
                                        <div class="item-tags">
                                            <span class="item-tag">Sınırlı Stok</span>

                                @* Sütun 3: Fiyat *@
                                <div class="item-price-col"
                                     aria-label="Fiyat: @item.MenuItemPrice.ToString("N2") Türk Lirası">
                                    <div class="item-price">
                                        <span class="item-price-currency">₺</span>@item.MenuItemPrice.ToString("N0")
                                    </div>
                                </div>
                            </div>
                        }
        function setLang(lang) {
            document.cookie = `qrmenu_lang=${lang};path=/;max-age=${30 * 24 * 3600};samesite=lax`;
            const url = new URL(window.location.href);
            url.searchParams.set('lang', lang);
            window.location.href = url.toString();
        }

        @* ════════════════════════════════════════════════════════
       FOOTER
       ════════════════════════════════════════════════════════ *@
        <footer class="qr-footer">
            <span class="footer-ornament">◆ &nbsp; ◆ &nbsp; ◆</span>
            btn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });

    <div class="toast-wrap" id="toastWrap" aria-live="polite"></div>

    <script>
        /* ════════════════════════════════════════════════════════════════
           KATEGORİ FİLTRELEME  (v2 — sayfa yenilenmeden gizle/göster)
           ════════════════════════════════════════════════════════════════
                gaps.forEach(g     => g.style.display = '');
             'all'   → tüm .menu-section'lar gösterilir, scroll spy devreye girer
             <id>    → yalnızca data-cat-id eşleşen section gösterilir; diğerleri
                       display:none olur; section-gap'ler de gizlenir.
        ════════════════════════════════════════════════════════════════ */

        // Şu an hangi filtre aktif ('all' veya kategori ID string'i)
                    window.scrollTo({ top: Math.max(0, target.getBoundingClientRect().top + window.scrollY - navH - 12), behavior: 'smooth' });
        function filterCategory(catId, btn) {
            document.querySelectorAll('.cat-nav-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');


            const sections = document.querySelectorAll('.menu-section');
            const gaps     = document.querySelectorAll('[data-gap]');

            if (catId === 'all') {
                sections.forEach(s => s.style.display = '');
                gaps.forEach(g     => g.style.display = '');

            } else {
                sections.forEach(s => { s.style.display = (s.dataset.catId === catId) ? '' : 'none'; });
                gaps.forEach(g => g.style.display = 'none');
                const target = document.querySelector(`.menu-section[data-cat-id="${catId}"]`);
                if (target) {
                        if (match) b.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
                    });
                });
            }, { rootMargin: `-${navH + 8}px 0px -60% 0px` });
        ════════════════════════════════════════════════════════════════ */
        (function initScrollSpy() {
            const sections = document.querySelectorAll('.menu-section[id]');
            const navBtns  = document.querySelectorAll('.cat-nav-btn');
            if (!sections.length) return;
            const navH = document.getElementById('catNavWrap')?.offsetHeight ?? 50;
            const observer = new IntersectionObserver(entries => {
                if (activeFilter !== 'all') return;
                entries.forEach(entry => {
                    if (!entry.isIntersecting) return;
                    const id = entry.target.dataset.catId;
                    navBtns.forEach(b => {
                        const match = b.dataset.cat === id;
                        b.classList.toggle('active', match);
                        if (match) {
                    btn.innerHTML = '<span class="btn-waiter-icon">✓</span><span>@T("waiterCalled")</span>';
                    showToast('@T("waiterMsg")');
                } else {
                    btn.disabled = false;
                }
            } catch {
                btn.disabled = false;
                showToast('@T("connError")');
            }
            sections.forEach(s => observer.observe(s));
        })();
        /* ════════════════════════════════════════════════════════════════
           TOAST
        ════════════════════════════════════════════════════════════════ */
        ════════════════════════════════════════════════════════════════ */
        const TABLE_NAME_JS = "@Html.Raw(tableName.Replace("\"", "\\\""))";
            const t    = document.createElement('div');
            t.className   = 'toast';
            t.textContent = msg;
            btn.disabled = true;
            try {
                const res  = await fetch('/QrMenu/CallWaiter', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ TableName: TABLE_NAME_JS }) });
                const data = await res.json();
                if (data.success) {
                    btn.innerHTML = '<span class="btn-waiter-icon">✓</span><span>Garson Çağrıldı</span>';
                    showToast('Garsonunuz en kısa sürede gelecek.');
                } else {
                    btn.disabled = false;
                }
            } catch {
                btn.disabled = false;
                showToast('Bağlantı hatası. Lütfen tekrar deneyiniz.');
            }
        }

        /* ════════════════════════════════════════════════════════════════
           TOAST
        ════════════════════════════════════════════════════════════════ */
        function showToast(msg) {
            const wrap = document.getElementById('toastWrap');
            const t = document.createElement('div');
            t.className = 'toast';
            t.textContent = msg;
            wrap.appendChild(t);
            requestAnimationFrame(() => requestAnimationFrame(() => t.classList.add('show')));
            setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 350); }, 3200);
        }
    </script>
</body>
</html>