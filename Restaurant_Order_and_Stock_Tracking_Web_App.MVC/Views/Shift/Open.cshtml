@{
    ViewData["Title"] = "Vardiya Aç";
}

@section Styles {
    <link href="~/css/Views/Shift/Index.css" rel="stylesheet" asp-append-version="true" />
}

<div class="z-header">
    <div>
        <h1>📋 Z-Raporu — Vardiya Aç</h1>
        <div class="sub">Gün başı kasa sayımını girerek vardiyayı başlatın.</div>
    </div>
    <a asp-action="Index" class="btn-z btn-z-ghost">← Geri</a>
</div>

<div id="alertBox"></div>

<div style="max-width:560px;margin:0 auto">
    <div class="z-card">
        <div class="z-card-title">Vardiya Bilgileri</div>

        <div style="margin-bottom:16px">
            <label style="font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);font-weight:600;display:block;margin-bottom:6px">
                Açılış Bakiyesi (₺) <span style="color:#ef4444">*</span>
            </label>
            <input type="number" id="openingBalance" class="form-control form-control-lg"
                   placeholder="0.00" min="0" step="0.01" value="0" />
            <div style="font-size:11px;color:var(--text-muted);margin-top:4px">Gün başında kasadaki nakit miktarı.</div>
        </div>

        <div style="margin-bottom:16px">
            <label style="font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);font-weight:600;display:block;margin-bottom:6px">
                Fark Uyarı Eşiği (₺)
            </label>
            <input type="number" id="threshold" class="form-control" placeholder="100.00" min="0" step="0.01" value="100" />
            <div style="font-size:11px;color:var(--text-muted);margin-top:4px">Bu miktarı aşan kasa farklarında SignalR uyarısı gönderilir.</div>
        </div>

        <div style="margin-bottom:20px">
            <label style="font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);font-weight:600;display:block;margin-bottom:6px">
                Notlar (opsiyonel)
            </label>
            <textarea id="notes" class="form-control" rows="3" placeholder="Açıklama..."></textarea>
        </div>

        <div style="display:flex;gap:10px">
            <button id="btnOpen" class="btn-z btn-z-success" style="flex:1;justify-content:center;padding:12px">
                ✅ Vardiyayı Başlat
            </button>
            <a asp-action="Index" class="btn-z btn-z-ghost" style="padding:12px 20px">İptal</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btnOpen').addEventListener('click', async function () {
            const openingBalance = parseFloat(document.getElementById('openingBalance').value) || 0;
            const threshold      = parseFloat(document.getElementById('threshold').value) || 100;
            const notes          = document.getElementById('notes').value.trim();

            this.disabled = true;
            this.textContent = 'Açılıyor…';

            try {
                const res  = await fetch('/Shift/Open', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ openingBalance, notes, differenceThreshold: threshold })
                });
                const data = await res.json();
                if (res.ok && data.success) {
                    window.location.href = `/Shift/Detail/${data.shiftId}`;
                } else {
                    showAlert(data.message || 'Vardiya açılamadı.');
                    this.disabled = false;
                    this.textContent = '✅ Vardiyayı Başlat';
                }
            } catch {
                showAlert('Sunucu hatası.');
                this.disabled = false;
                this.textContent = '✅ Vardiyayı Başlat';
            }
        });

        function showAlert(msg) {
            document.getElementById('alertBox').innerHTML =
                `<div style="background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);border-radius:10px;padding:12px 16px;font-size:13px;color:#ef4444;margin-bottom:16px">${msg}</div>`;
        }
    </script>
}
