@*
    Views/Home/Index.cshtml  —  Dashboard Komuta Merkezi
    Yol: Restaurant_Order_and_Stock_Tracking_Web_App.MVC/Views/Home/Index.cshtml
*@
@model Restaurant_Order_and_Stock_Tracking_Web_App.MVC.ViewModels.Dashboard.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Trend badge yardımcıları
    string TrendClass(decimal? pct) => pct switch
    {
        null               => "neutral",
        > 0                => "up",
        < 0                => "down",
        _                  => "neutral"
    };

    string TrendIcon(decimal? pct) => pct switch
    {
        null => "—",
        > 0  => "↑",
        < 0  => "↓",
        _    => "—"
    };

    string TrendText(decimal? pct) => pct switch
    {
        null  => "Dünkü veri yok",
        var p => $"{TrendIcon(p)} %{Math.Abs(p.Value):F1}"
    };

    // Masa doluluk oranı bar genişlikleri
    var ts = Model.TableStatus;
    double occPct = ts.Total > 0 ? (double)ts.Occupied / ts.Total * 100 : 0;
    double resPct = ts.Total > 0 ? (double)ts.Reserved / ts.Total * 100 : 0;
    double empPct = ts.Total > 0 ? (double)ts.Empty    / ts.Total * 100 : 0;

    // Top ürün maksimum adedi (progress bar için)
    int maxQty = Model.TopSellingProducts.Any()
        ? Model.TopSellingProducts.Max(p => p.Quantity)
        : 1;
}

@section Styles {
    <link href="~/css/Views/Home/Index.css" rel="stylesheet" asp-append-version="true" />
}

@* ── BAŞLIK ─────────────────────────────────────────────────────────────── *@
<div class="dash-header">
    <div>
        <h1 class="dash-title">📊 Dashboard</h1>
        <div class="dash-subtitle">Anlık operasyon özeti — <span class="dash-date">@DateTime.Now.ToString("dd MMMM yyyy, HH:mm", new System.Globalization.CultureInfo("tr-TR"))</span></div>
    </div>
    <a asp-controller="Reports" asp-action="Index" class="btn btn-ghost" style="font-size:.8rem;">
        📈 Raporlar →
    </a>
</div>

@* ── ALARM ŞERİDİ ────────────────────────────────────────────────────────── *@
@if (Model.WaiterCallsActive > 0 || Model.LowStockAlerts > 0 || Model.ActiveOrdersNow > 0)
{
    <div class="alert-strip">
        @if (Model.ActiveOrdersNow > 0)
        {
            <a asp-controller="Orders" asp-action="Index" class="alert-chip chip-orange">
                🧾 @Model.ActiveOrdersNow aktif sipariş
            </a>
        }
        @if (Model.WaiterCallsActive > 0)
        {
            <a asp-controller="Tables" asp-action="Index" class="alert-chip chip-red">
                🔔 @Model.WaiterCallsActive garson çağrısı
            </a>
        }
        @if (Model.LowStockAlerts > 0)
        {
            <a asp-controller="Stock" asp-action="Index" class="alert-chip chip-red">
                ⚠️ @Model.LowStockAlerts kritik stok
            </a>
        }
    </div>
}

@* ══════════════════════════════════════════════════════════════════════════
   KPI KARTLARI — 4'lü Bento Grid
   ══════════════════════════════════════════════════════════════════════════ *@
<div class="kpi-grid">

    @* ── Kart 1: Günlük Ciro ── *@
    <div class="bento-card">
        <div class="kpi-icon">💰</div>
        <div class="kpi-label">Günlük Ciro</div>
        <div class="kpi-value">₺@Model.DailyTotalRevenue.ToString("N0")</div>
        <span class="kpi-badge @TrendClass(Model.RevenueTrendPercentage)">
            @TrendText(Model.RevenueTrendPercentage)
        </span>
        <div class="kpi-meta">Düne kıyasla</div>
    </div>

    @* ── Kart 2: Sipariş Adedi ── *@
    <div class="bento-card">
        <div class="kpi-icon">🧾</div>
        <div class="kpi-label">Sipariş Adedi</div>
        <div class="kpi-value">@Model.TotalOrdersToday</div>
        <div class="kpi-meta">
            <span class="kpi-active-dot"></span>
            @Model.ActiveOrdersNow aktif &nbsp;·&nbsp;
            @(Model.TotalOrdersToday - Model.ActiveOrdersNow) kapandı
        </div>
    </div>

    @* ── Kart 3: Adisyon Ortalaması ── *@
    <div class="bento-card">
        <div class="kpi-icon">📊</div>
        <div class="kpi-label">Adisyon Ortalaması</div>
        <div class="kpi-value">₺@Model.AverageOrderValue.ToString("N0")</div>
        <div class="kpi-meta">Kapanan siparişlerin ortalaması</div>
    </div>

    @* ── Kart 4: Masa Durumu ── *@
    <div class="bento-card">
        <div class="kpi-icon">🪑</div>
        <div class="kpi-label">Masa Durumu</div>
        <div class="kpi-value">
            @ts.Occupied <span style="font-size:1rem;font-weight:400;color:var(--text-muted);">/ @ts.Total dolu</span>
        </div>

        @* Doluluk çubuğu *@
        <div class="table-status-bar">
            <div class="tsb-segment tsb-occupied" style="width:@occPct.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)%"></div>
            <div class="tsb-segment tsb-reserved" style="width:@resPct.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)%"></div>
            <div class="tsb-segment tsb-empty"    style="width:@empPct.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)%"></div>
        </div>

        <div class="table-legend">
            <div class="tl-item">
                <div class="tl-dot" style="background:var(--accent)"></div>
                <span>Dolu (@ts.Occupied)</span>
            </div>
            <div class="tl-item">
                <div class="tl-dot" style="background:#3B82F6"></div>
                <span>Rezerve (@ts.Reserved)</span>
            </div>
            <div class="tl-item">
                <div class="tl-dot" style="background:var(--border)"></div>
                <span>Boş (@ts.Empty)</span>
            </div>
        </div>
    </div>

</div>

@* ══════════════════════════════════════════════════════════════════════════
   GRAFİK SATIRI — Sol: Line Chart | Sağ: Doughnut + Liste
   ══════════════════════════════════════════════════════════════════════════ *@
<div class="chart-grid">

    @* ── Sol: Saatlik Yoğunluk (Line Chart) ── *@
    <div class="chart-card">
        <div class="chart-card-header">
            <div>
                <div class="chart-card-title">⏱️ Saatlik Sipariş Yoğunluğu</div>
                <div class="chart-card-sub">Bugünün saat bazında sipariş akışı</div>
            </div>
            <span class="chart-tag">Bugün</span>
        </div>

        @if (Model.HourlyOrderTrends.All(h => h.OrderCount == 0))
        {
            <div class="chart-empty">
                <div class="chart-empty-icon">📭</div>
                <span>Bugün henüz sipariş yok</span>
            </div>
        }
        else
        {
            <div class="chart-wrap">
                <canvas id="lineChart" height="220"></canvas>
            </div>
        }
    </div>

    @* ── Sağ: En Çok Satanlar (Doughnut + Liste) ── *@
    <div class="chart-card">
        <div class="chart-card-header">
            <div>
                <div class="chart-card-title">🏆 En Çok Satanlar</div>
                <div class="chart-card-sub">Bugünün top 5 ürünü</div>
            </div>
            <span class="chart-tag">Top 5</span>
        </div>

        @if (!Model.TopSellingProducts.Any())
        {
            <div class="chart-empty">
                <div class="chart-empty-icon">📭</div>
                <span>Henüz satış verisi yok</span>
            </div>
        }
        else
        {
            @* Doughnut Grafik *@
            <div class="doughnut-wrap">
                <canvas id="doughnutChart" height="220"></canvas>
                <div class="doughnut-center">
                    <div class="dc-label">toplam</div>
                    <div class="dc-value">@Model.TopSellingProducts.Sum(p => p.Quantity)</div>
                    <div class="dc-label">adet</div>
                </div>
            </div>

            @* Sıralı liste *@
            <div class="top-list">
                @for (int i = 0; i < Model.TopSellingProducts.Count; i++)
                {
                    var p    = Model.TopSellingProducts[i];
                    var pct  = maxQty > 0 ? (int)Math.Round((double)p.Quantity / maxQty * 100) : 0;
                    <div class="top-item">
                        <div class="top-rank">#@(i + 1)</div>
                        <div class="top-name" title="@p.ProductName">@p.ProductName</div>
                        <div class="top-bar-wrap">
                            <div class="top-bar" style="width:@pct%"></div>
                        </div>
                        <div class="top-qty">@p.Quantity adet</div>
                    </div>
                }
            </div>
        }
    </div>

</div>

@* ══════════════════════════════════════════════════════════════════════════
   CHART.JS VERİ AKIŞI VE KURULUM
   ══════════════════════════════════════════════════════════════════════════ *@
@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>

    <script>
    // ── Razor → JS Veri Köprüsü ─────────────────────────────────────────────
    const hourlyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.HourlyOrderTrends.Select(h => new {
            label      = h.HourLabel,
            orderCount = h.OrderCount,
            revenue    = (double)h.Revenue
        })
    ));

    const topData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.TopSellingProducts.Select(p => new {
            name     = p.ProductName,
            quantity = p.Quantity,
            revenue  = (double)p.Revenue
        })
    ));

    // ── Tema Renkleri ────────────────────────────────────────────────────────
    const accent    = '#F97316';
    const isDark    = document.documentElement.getAttribute('data-theme') !== 'light';
    const gridColor = isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.06)';
    const textColor = isDark ? '#687080'                : '#8A95A3';

    // ── Genel Plugin Varsayılanları ──────────────────────────────────────────
    Chart.defaults.font.family  = "'DM Sans', sans-serif";
    Chart.defaults.font.size    = 11;
    Chart.defaults.color        = textColor;

    // ══════════════════════════════════════════════════════════════════════════
    // 1. LINE CHART  —  Saatlik Sipariş Yoğunluğu
    // ══════════════════════════════════════════════════════════════════════════
    const lineCanvas = document.getElementById('lineChart');
    if (lineCanvas && hourlyData.length > 0) {

        const ctx = lineCanvas.getContext('2d');

        // Turuncu degrade dolgu
        const gradient = ctx.createLinearGradient(0, 0, 0, 260);
        gradient.addColorStop(0,   'rgba(249,115,22,0.28)');
        gradient.addColorStop(0.6, 'rgba(249,115,22,0.06)');
        gradient.addColorStop(1,   'rgba(249,115,22,0.00)');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels:   hourlyData.map(h => h.label),
                datasets: [{
                    label:           'Sipariş Adedi',
                    data:            hourlyData.map(h => h.orderCount),
                    borderColor:     accent,
                    backgroundColor: gradient,
                    borderWidth:     2.5,
                    pointRadius:     4,
                    pointBackgroundColor: accent,
                    pointBorderColor:    isDark ? '#161A20' : '#fff',
                    pointBorderWidth:    2,
                    pointHoverRadius:    6,
                    fill:            true,
                    tension:         0.38
                }]
            },
            options: {
                responsive:          true,
                maintainAspectRatio: false,
                animation: {
                    duration: 900,
                    easing:   'easeOutQuart'
                },
                interaction: {
                    mode:      'index',
                    intersect: false
                },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: isDark ? '#1E242C' : '#fff',
                        borderColor:     isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.08)',
                        borderWidth:     1,
                        titleColor:      isDark ? '#EEF0F3' : '#141A22',
                        bodyColor:       textColor,
                        padding:         10,
                        callbacks: {
                            label: ctx => ` ${ctx.parsed.y} sipariş`
                        }
                    }
                },
                scales: {
                    x: {
                        grid:    { color: gridColor },
                        ticks:   { color: textColor, maxTicksLimit: 10 },
                        border:  { display: false }
                    },
                    y: {
                        beginAtZero: true,
                        grid:   { color: gridColor },
                        ticks:  {
                            color:     textColor,
                            stepSize:  1,
                            callback:  val => Number.isInteger(val) ? val : ''
                        },
                        border: { display: false }
                    }
                }
            }
        });
    }

    // ══════════════════════════════════════════════════════════════════════════
    // 2. DOUGHNUT CHART  —  En Çok Satan Ürünler
    // ══════════════════════════════════════════════════════════════════════════
    const donutCanvas = document.getElementById('doughnutChart');
    if (donutCanvas && topData.length > 0) {

        // Lüks & modern renk paleti
        const palette = [
            '#F97316',  // turuncu (accent)
            '#C5A059',  // altın
            '#E2C278',  // açık altın
            '#3B82F6',  // mavi vurgu
            isDark ? '#CBD5E1' : '#64748B'  // gri/krem
        ];

        new Chart(donutCanvas.getContext('2d'), {
            type: 'doughnut',
            data: {
                labels:   topData.map(p => p.name),
                datasets: [{
                    data:             topData.map(p => p.quantity),
                    backgroundColor:  palette,
                    borderColor:      isDark ? '#161A20' : '#fff',
                    borderWidth:      3,
                    hoverBorderWidth: 3,
                    hoverOffset:      8
                }]
            },
            options: {
                responsive:          true,
                maintainAspectRatio: false,
                cutout:              '70%',
                animation: {
                    duration:          800,
                    animateRotate:     true,
                    animateScale:      false
                },
                plugins: {
                    legend: {
                        display: false  // Kendi listemi kullanıyoruz
                    },
                    tooltip: {
                        backgroundColor: isDark ? '#1E242C' : '#fff',
                        borderColor:     isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.08)',
                        borderWidth:     1,
                        titleColor:      isDark ? '#EEF0F3' : '#141A22',
                        bodyColor:       textColor,
                        padding:         10,
                        callbacks: {
                            label: ctx => ` ${ctx.parsed} adet`
                        }
                    }
                }
            }
        });
    }

    // ── Tema değiştiğinde grafikleri yenile ─────────────────────────────────
    // site.css'teki theme toggle butonu tetiklediğinde sayfayı yenile
    const themeToggleBtn = document.getElementById('themeToggle');
    if (themeToggleBtn) {
        themeToggleBtn.addEventListener('click', () => {
            setTimeout(() => location.reload(), 100);
        });
    }
    </script>
}
