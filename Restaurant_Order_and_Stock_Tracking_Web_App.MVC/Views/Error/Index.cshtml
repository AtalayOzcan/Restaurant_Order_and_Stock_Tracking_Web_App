@*
    Views/Error/Index.cshtml
    RestaurantOS — 500 Genel Hata Sayfası

    Layout = null — Standalone, kendi CSS'ini taşır.
    Ana layout kullanılmıyor; hata anında DB sorguları da çökmüş olabilir.
    Tasarım DNA: Koyu Mor (#1E1B4B) + Playfair Display + Lato + Glassmorphism
*@
@{
    Layout = null;
    ViewData["Title"] = "Sistem Hatası — RestaurantOS";

    // ErrorController tarafından sadece Development modunda doldurulur
    bool hasTechDetails = ViewBag.FailedPath != null;
}
<!DOCTYPE html>
<html lang="tr" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />

    <style>
            *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

            :root {
                --bg:        #1E1B4B;
                --bg-deep:   #151231;
                --surface:   #2D2A6E;
                --surface2:  #373480;
                --accent:    #818CF8;
                --accent-dk: #6366F1;
                --accent-glow: rgba(129,140,248,0.25);
                --text:      #F1F5F9;
                --muted:     #94A3B8;
                --border:    rgba(129,140,248,0.18);
                --shadow:    0 8px 32px rgba(0,0,0,0.55);
                --red:       #F87171;
                --red-bg:    rgba(248,113,113,0.12);
            }

            body {
                min-height: 100vh;
                background: var(--bg-deep);
                background-image:
                    radial-gradient(ellipse 80% 60% at 50% -10%, rgba(99,102,241,0.25) 0%, transparent 70%),
                    radial-gradient(ellipse 40% 40% at 80% 90%, rgba(129,140,248,0.10) 0%, transparent 60%);
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'Lato', sans-serif;
                color: var(--text);
                padding: 2rem 1rem;
            }

            /* ── Kart ──────────────────────────────── */
            .card {
                width: 100%;
                max-width: 560px;
                background: rgba(45,42,110,0.55);
                backdrop-filter: blur(18px);
                -webkit-backdrop-filter: blur(18px);
                border: 1px solid var(--border);
                border-radius: 24px;
                padding: 3rem 2.5rem;
                box-shadow: var(--shadow);
                text-align: center;
            }

            /* ── İkon ──────────────────────────────── */
            .icon-wrap {
                width: 96px;
                height: 96px;
                border-radius: 50%;
                background: var(--red-bg);
                border: 2px solid rgba(248,113,113,0.3);
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 2rem;
                font-size: 2.8rem;
                animation: pulse 2.5s infinite;
            }

            @@keyframes pulse {
                0%, 100% { box-shadow: 0 0 0 0 rgba(248,113,113,0.3); }
                50%       { box-shadow: 0 0 0 14px rgba(248,113,113,0); }
            }

            /* ── Metinler ──────────────────────────── */
            .badge {
                display: inline-block;
                background: var(--red-bg);
                color: var(--red);
                border: 1px solid rgba(248,113,113,0.3);
                border-radius: 20px;
                padding: 0.25rem 1rem;
                font-size: 0.78rem;
                font-weight: 700;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                margin-bottom: 1.2rem;
            }

            h1 {
                font-family: 'Playfair Display', serif;
                font-size: clamp(1.4rem, 3.5vw, 1.9rem);
                font-weight: 800;
                line-height: 1.3;
                margin-bottom: 1rem;
                color: var(--text);
            }

            .desc {
                color: var(--muted);
                font-size: 1rem;
                line-height: 1.7;
                margin-bottom: 2rem;
            }

            /* ── Butonlar ──────────────────────────── */
            .btn-primary {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                background: linear-gradient(135deg, var(--accent-dk) 0%, var(--accent) 100%);
                color: #fff;
                font-family: 'Lato', sans-serif;
                font-weight: 700;
                font-size: 0.95rem;
                padding: 0.8rem 2rem;
                border-radius: 12px;
                border: none;
                cursor: pointer;
                text-decoration: none;
                transition: all 0.2s;
                box-shadow: 0 4px 18px var(--accent-glow);
            }
            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 28px var(--accent-glow);
            }

            .btn-ghost {
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
                background: transparent;
                color: var(--muted);
                font-family: 'Lato', sans-serif;
                font-weight: 400;
                font-size: 0.88rem;
                padding: 0.6rem 1.2rem;
                border-radius: 10px;
                border: 1px solid var(--border);
                cursor: pointer;
                text-decoration: none;
                margin-left: 0.75rem;
                transition: all 0.2s;
            }
            .btn-ghost:hover {
                background: rgba(129,140,248,0.08);
                color: var(--text);
            }

            /* ── Teknik Detay Kutusu (sadece DEV) ─── */
            .dev-panel {
                margin-top: 2rem;
                border: 1px solid rgba(248,113,113,0.25);
                border-radius: 14px;
                overflow: hidden;
                text-align: left;
            }

            .dev-panel summary {
                background: rgba(248,113,113,0.10);
                color: var(--red);
                padding: 0.75rem 1rem;
                cursor: pointer;
                font-size: 0.82rem;
                font-weight: 700;
                letter-spacing: 0.04em;
                list-style: none;
                display: flex;
                align-items: center;
                gap: 0.5rem;
                user-select: none;
            }
            .dev-panel summary::-webkit-details-marker { display: none; }
            .dev-panel[open] summary { border-bottom: 1px solid rgba(248,113,113,0.2); }

            .dev-panel-body {
                padding: 1rem;
                background: rgba(0,0,0,0.25);
            }

            .dev-row {
                display: grid;
                grid-template-columns: 110px 1fr;
                gap: 0.4rem 0.75rem;
                margin-bottom: 0.6rem;
            }
            .dev-label {
                color: var(--muted);
                font-size: 0.78rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.06em;
                padding-top: 0.1rem;
            }
            .dev-value {
                background: rgba(0,0,0,0.3);
                border: 1px solid var(--border);
                border-radius: 6px;
                padding: 0.3rem 0.6rem;
                font-family: 'Courier New', monospace;
                font-size: 0.8rem;
                color: #fbbf24;
                word-break: break-all;
            }

            /* ── Altbilgi ──────────────────────────── */
            .footer-note {
                margin-top: 2.5rem;
                padding-top: 1.5rem;
                border-top: 1px solid var(--border);
                color: var(--muted);
                font-size: 0.8rem;
            }
            .footer-note span {
                color: var(--accent);
                font-weight: 700;
            }
    </style>
</head>
<body>
    <div class="card">

        <div class="icon-wrap">🍳</div>

        <div class="badge">Sistem Hatası</div>

        <h1>Eyvah! Mutfakta Küçük Bir Kaza Oldu</h1>

        <p class="desc">
            Sistemde beklenmedik bir hata oluştu.<br>
            Teknik ekibimiz durumdan haberdar edildi ve en kısa sürede çözüme kavuşturulacak.
        </p>

        <a href="/" class="btn-primary">
            🏠 Ana Sayfaya Dön
        </a>
        <a href="javascript:history.back()" class="btn-ghost">
            ← Geri Git
        </a>

        @* ── Teknik Detay Paneli — SADECE Development modunda görünür ─── *@
        @if (hasTechDetails)
        {
            <details class="dev-panel">
                <summary>
                    🛠 Teknik Detaylar (Geliştirici Modu)
                </summary>
                <div class="dev-panel-body">
                    @if (ViewBag.FailedPath != null)
                    {
                        <div class="dev-row">
                            <span class="dev-label">Path</span>
                            <span class="dev-value">@ViewBag.FailedPath</span>
                        </div>
                    }
                    @if (ViewBag.ExceptionType != null)
                    {
                        <div class="dev-row">
                            <span class="dev-label">Tür</span>
                            <span class="dev-value">@ViewBag.ExceptionType</span>
                        </div>
                    }
                    @if (ViewBag.ExceptionMsg != null)
                    {
                        <div class="dev-row">
                            <span class="dev-label">Mesaj</span>
                            <span class="dev-value">@ViewBag.ExceptionMsg</span>
                        </div>
                    }
                </div>
            </details>
        }

        <div class="footer-note">
            <span>RestaurantOS</span> — Restoran Yönetim Sistemi
        </div>

    </div>
</body>
</html>
