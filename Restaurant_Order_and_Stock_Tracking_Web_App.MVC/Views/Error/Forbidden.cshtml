@*
    Views/Error/Forbidden.cshtml
    RestaurantOS — 403 Yetkisiz Erişim Sayfası

    Layout = null — Standalone, kendi CSS'ini taşır.
    Tasarım DNA: Koyu Mor (#1E1B4B) + Playfair Display + Lato + Glassmorphism
*@
@{
    Layout = null;
    ViewData["Title"] = "403 — Yetkisiz Erişim · RestaurantOS";
}
<!DOCTYPE html>
<html lang="tr" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg-deep:   #151231;
            --surface:   #2D2A6E;
            --accent:    #818CF8;
            --accent-dk: #6366F1;
            --accent-glow: rgba(129,140,248,0.25);
            --text:      #F1F5F9;
            --muted:     #94A3B8;
            --border:    rgba(129,140,248,0.18);
            --shadow:    0 8px 32px rgba(0,0,0,0.55);
            --orange:    #FB923C;
            --orange-bg: rgba(251,146,60,0.10);
        }

        body {
            min-height: 100vh;
            background: var(--bg-deep);
            background-image:
                radial-gradient(ellipse 80% 60% at 50% -10%, rgba(99,102,241,0.20) 0%, transparent 70%),
                radial-gradient(ellipse 40% 40% at 85% 85%, rgba(251,146,60,0.08) 0%, transparent 60%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Lato', sans-serif;
            color: var(--text);
            padding: 2rem 1rem;
        }

        .card {
            width: 100%;
            max-width: 560px;
            background: rgba(45,42,110,0.55);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 3rem 2.5rem;
            box-shadow: var(--shadow);
            text-align: center;
        }

        /* ── İkon ──────────────────────────────── */
        .icon-lock {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            background: var(--orange-bg);
            border: 2px solid rgba(251,146,60,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2.6rem;
            animation: shake 4s ease-in-out infinite;
        }

        @@keyframes shake {
            0%, 85%, 100% { transform: rotate(0deg); }
            87%  { transform: rotate(-6deg); }
            89%  { transform: rotate(6deg); }
            91%  { transform: rotate(-4deg); }
            93%  { transform: rotate(4deg); }
            95%  { transform: rotate(-2deg); }
            97%  { transform: rotate(0deg); }
        }

        /* ── 403 Numara ────────────────────────── */
        .big-number {
            font-family: 'Playfair Display', serif;
            font-size: clamp(4rem, 15vw, 6.5rem);
            font-weight: 800;
            line-height: 1;
            background: linear-gradient(135deg, var(--orange) 0%, #FBBF24 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.5rem;
            letter-spacing: -0.02em;
        }

        .badge {
            display: inline-block;
            background: var(--orange-bg);
            color: var(--orange);
            border: 1px solid rgba(251,146,60,0.3);
            border-radius: 20px;
            padding: 0.25rem 1rem;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 1.2rem;
        }

        h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(1.3rem, 3.5vw, 1.75rem);
            font-weight: 800;
            line-height: 1.3;
            margin-bottom: 1rem;
        }

        .desc {
            color: var(--muted);
            font-size: 1rem;
            line-height: 1.7;
            margin-bottom: 2rem;
        }

        /* ── Bilgi Kutusu ──────────────────────── */
        .info-box {
            background: rgba(251,146,60,0.08);
            border: 1px solid rgba(251,146,60,0.2);
            border-radius: 14px;
            padding: 1rem 1.25rem;
            margin-bottom: 2rem;
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            text-align: left;
        }
        .info-box .info-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 0.1rem; }
        .info-box .info-text { font-size: 0.88rem; color: var(--muted); line-height: 1.6; }
        .info-box .info-text strong { color: var(--orange); font-weight: 700; }

        /* ── Butonlar ──────────────────────────── */
        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: linear-gradient(135deg, var(--accent-dk) 0%, var(--accent) 100%);
            color: #fff;
            font-family: 'Lato', sans-serif;
            font-weight: 700;
            font-size: 0.95rem;
            padding: 0.8rem 2rem;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s;
            box-shadow: 0 4px 18px var(--accent-glow);
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px var(--accent-glow);
        }

        .btn-ghost {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: transparent;
            color: var(--muted);
            font-family: 'Lato', sans-serif;
            font-weight: 400;
            font-size: 0.88rem;
            padding: 0.6rem 1.2rem;
            border-radius: 10px;
            border: 1px solid var(--border);
            cursor: pointer;
            text-decoration: none;
            margin-left: 0.75rem;
            transition: all 0.2s;
        }
        .btn-ghost:hover {
            background: rgba(129,140,248,0.08);
            color: var(--text);
        }

        /* ── Login ipucu ───────────────────────── */
        .login-hint {
            margin-top: 1.5rem;
            font-size: 0.85rem;
            color: var(--muted);
        }
        .login-hint a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 700;
        }
        .login-hint a:hover { text-decoration: underline; }

        .footer-note {
            margin-top: 2.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border);
            color: var(--muted);
            font-size: 0.8rem;
        }
        .footer-note span { color: var(--accent); font-weight: 700; }
    </style>
</head>
<body>
    <div class="card">

        <div class="icon-lock">🔒</div>

        <div class="big-number">403</div>

        <div class="badge">Yetkisiz Erişim</div>

        <h1>Bu Alana Giriş Yetkiniz Yok</h1>

        <p class="desc">
            Sadece yetkili personelin veya yöneticilerin<br>
            girebileceği bir sayfaya erişmeye çalıştınız.
        </p>

        <div class="info-box">
            <span class="info-icon">💡</span>
            <div class="info-text">
                <strong>Ne yapmalısınız?</strong><br>
                Eğer bu sayfaya erişim hakkınız olması gerektiğini düşünüyorsanız,
                lütfen sistem yöneticinizle iletişime geçin veya
                yetkili hesabınızla tekrar giriş yapın.
            </div>
        </div>

        <a href="/" class="btn-primary">
            🏠 Ana Sayfaya Dön
        </a>
        <a href="javascript:history.back()" class="btn-ghost">
            ← Geri Git
        </a>

        <div class="login-hint">
            Farklı bir hesapla giriş yapmak ister misiniz?
            <a href="/App/Auth/Login">Giriş Yap →</a>
        </div>

        <div class="footer-note">
            <span>RestaurantOS</span> — Restoran Yönetim Sistemi
        </div>

    </div>
</body>
</html>
