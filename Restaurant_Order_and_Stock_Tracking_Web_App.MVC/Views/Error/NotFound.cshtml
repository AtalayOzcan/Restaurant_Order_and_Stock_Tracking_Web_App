@*
    Views/Error/NotFound.cshtml
    RestaurantOS — 404 Bulunamadı Sayfası

    Layout = null — Standalone, kendi CSS'ini taşır.
    Tasarım DNA: Koyu Mor (#1E1B4B) + Playfair Display + Lato + Glassmorphism
*@
@{
    Layout = null;
    ViewData["Title"] = "404 — Sayfa Bulunamadı · RestaurantOS";
}
<!DOCTYPE html>
<html lang="tr" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:        #1E1B4B;
            --bg-deep:   #151231;
            --surface:   #2D2A6E;
            --accent:    #818CF8;
            --accent-dk: #6366F1;
            --accent-glow: rgba(129,140,248,0.25);
            --text:      #F1F5F9;
            --muted:     #94A3B8;
            --border:    rgba(129,140,248,0.18);
            --shadow:    0 8px 32px rgba(0,0,0,0.55);
            --amber:     #FBBF24;
            --amber-bg:  rgba(251,191,36,0.10);
        }

        body {
            min-height: 100vh;
            background: var(--bg-deep);
            background-image:
                radial-gradient(ellipse 80% 60% at 50% -10%, rgba(99,102,241,0.20) 0%, transparent 70%),
                radial-gradient(ellipse 35% 35% at 15% 80%, rgba(251,191,36,0.08) 0%, transparent 60%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Lato', sans-serif;
            color: var(--text);
            padding: 2rem 1rem;
        }

        .card {
            width: 100%;
            max-width: 560px;
            background: rgba(45,42,110,0.55);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 3rem 2.5rem;
            box-shadow: var(--shadow);
            text-align: center;
        }

        /* ── 404 Büyük numara ──────────────────── */
        .big-number {
            font-family: 'Playfair Display', serif;
            font-size: clamp(5rem, 18vw, 8rem);
            font-weight: 800;
            line-height: 1;
            background: linear-gradient(135deg, var(--accent-dk) 0%, var(--amber) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.25rem;
            letter-spacing: -0.03em;
        }

        .icon-wrap {
            font-size: 2.2rem;
            margin-bottom: 1.5rem;
            display: block;
        }

        .badge {
            display: inline-block;
            background: var(--amber-bg);
            color: var(--amber);
            border: 1px solid rgba(251,191,36,0.3);
            border-radius: 20px;
            padding: 0.25rem 1rem;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 1.2rem;
        }

        h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(1.3rem, 3.5vw, 1.75rem);
            font-weight: 800;
            line-height: 1.3;
            margin-bottom: 1rem;
        }

        .desc {
            color: var(--muted);
            font-size: 1rem;
            line-height: 1.7;
            margin-bottom: 2rem;
        }

        /* ── Öneri Kartları ────────────────────── */
        .suggestions {
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
            margin-bottom: 2rem;
            text-align: left;
        }

        .suggestion-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            background: rgba(129,140,248,0.07);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 0.75rem 1rem;
            text-decoration: none;
            color: var(--text);
            font-size: 0.9rem;
            transition: all 0.2s;
        }
        .suggestion-item:hover {
            background: rgba(129,140,248,0.15);
            border-color: rgba(129,140,248,0.35);
            transform: translateX(3px);
        }
        .suggestion-item .s-icon {
            font-size: 1.2rem;
            flex-shrink: 0;
        }
        .suggestion-item .s-label {
            font-weight: 700;
            font-size: 0.88rem;
        }
        .suggestion-item .s-desc {
            color: var(--muted);
            font-size: 0.8rem;
        }

        /* ── Butonlar ──────────────────────────── */
        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: linear-gradient(135deg, var(--accent-dk) 0%, var(--accent) 100%);
            color: #fff;
            font-family: 'Lato', sans-serif;
            font-weight: 700;
            font-size: 0.95rem;
            padding: 0.8rem 2rem;
            border-radius: 12px;
            border: none;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s;
            box-shadow: 0 4px 18px var(--accent-glow);
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px var(--accent-glow);
        }

        .footer-note {
            margin-top: 2.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--border);
            color: var(--muted);
            font-size: 0.8rem;
        }
        .footer-note span { color: var(--accent); font-weight: 700; }

        /* ── Yüzen parçacıklar ─────────────────── */
        .float-items {
            position: fixed;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
            z-index: 0;
        }
        .float-item {
            position: absolute;
            font-size: 1.5rem;
            opacity: 0.07;
            animation: floatUp 8s linear infinite;
        }
        .float-item:nth-child(1) { left: 5%;  animation-delay: 0s;   animation-duration: 9s; }
        .float-item:nth-child(2) { left: 20%; animation-delay: 2s;   animation-duration: 11s; }
        .float-item:nth-child(3) { left: 40%; animation-delay: 1s;   animation-duration: 8s; }
        .float-item:nth-child(4) { left: 65%; animation-delay: 3.5s; animation-duration: 10s; }
        .float-item:nth-child(5) { left: 85%; animation-delay: 0.5s; animation-duration: 12s; }

        @@keyframes floatUp {
            0%   { transform: translateY(110vh) rotate(0deg); opacity: 0; }
            10%  { opacity: 0.07; }
            90%  { opacity: 0.07; }
            100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
        }

        .card { position: relative; z-index: 1; }
    </style>
</head>
<body>

    <div class="float-items" aria-hidden="true">
        <div class="float-item">🍽️</div>
        <div class="float-item">🥄</div>
        <div class="float-item">🍴</div>
        <div class="float-item">🥂</div>
        <div class="float-item">🧂</div>
    </div>

    <div class="card">

        <div class="big-number">404</div>

        <span class="icon-wrap">🗺️</span>

        <div class="badge">Sayfa Bulunamadı</div>

        <h1>Aradığınız Sayfa Menümüzde Yok</h1>

        <p class="desc">
            Girmeye çalıştığınız sayfa taşınmış veya silinmiş olabilir.<br>
            Siparişinize aşağıdaki bağlantılardan devam edebilirsiniz.
        </p>

        <div class="suggestions">
            <a href="/" class="suggestion-item">
                <span class="s-icon">🏠</span>
                <div>
                    <div class="s-label">Ana Sayfa</div>
                    <div class="s-desc">RestaurantOS giriş sayfasına dön</div>
                </div>
            </a>
            <a href="/App/Tables" class="suggestion-item">
                <span class="s-icon">🪑</span>
                <div>
                    <div class="s-label">Masa Yönetimi</div>
                    <div class="s-desc">Masaları görüntüle ve yönet</div>
                </div>
            </a>
            <a href="/App/Orders" class="suggestion-item">
                <span class="s-icon">📋</span>
                <div>
                    <div class="s-label">Siparişler</div>
                    <div class="s-desc">Aktif siparişleri görüntüle</div>
                </div>
            </a>
        </div>

        <a href="javascript:history.back()" class="btn-primary">
            ← Önceki Sayfaya Dön
        </a>

        <div class="footer-note">
            <span>RestaurantOS</span> — Restoran Yönetim Sistemi
        </div>

    </div>
</body>
</html>
